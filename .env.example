# Serveur
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# MongoDB — sans nom de db, il est derive depuis NODE_ENV (buvard-dev / buvard-prod / buvard-test)
MONGODB_URI=mongodb://localhost:27017

# CORS — origines autorisees, separees par virgule
CORS_ORIGINS=http://localhost:5173,capacitor://localhost,http://localhost

# Better Auth — secret pour signer cookies / tokens de session
# Generer avec: openssl rand -hex 32
BETTER_AUTH_SECRET=replace_me_with_a_32_plus_char_random_secret

# Google OAuth (social provider Better Auth)
# Cree dans Google Cloud Console (type "Web application")
# Redirect URI a allowlister cote Google : <PUBLIC_API_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# URL publique de l'API (sans slash final). Utilisee comme baseURL Better Auth.
PUBLIC_API_URL=https://api-staging.buvard.app

# Cloudflare R2 (https://dash.cloudflare.com/?to=/:account/r2)
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=buvard-media
R2_PUBLIC_URL=https://pub-xxx.r2.dev
