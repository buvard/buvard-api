# Serveur
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# MongoDB — sans nom de db, il est derive depuis NODE_ENV (buvard-dev / buvard-prod / buvard-test)
MONGODB_URI=mongodb://localhost:27017

# CORS — origines autorisees, separees par virgule
CORS_ORIGINS=http://localhost:5173,capacitor://localhost,http://localhost

# Clerk (https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Bundle ID de l'app native pour le pont OAuth (/oauth-bridge)
# staging -> app.buvard.staging, prod -> app.buvard
APP_BUNDLE_ID=app.buvard.staging

# Cloudflare R2 (https://dash.cloudflare.com/?to=/:account/r2)
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET=buvard-media
R2_PUBLIC_URL=https://pub-xxx.r2.dev
